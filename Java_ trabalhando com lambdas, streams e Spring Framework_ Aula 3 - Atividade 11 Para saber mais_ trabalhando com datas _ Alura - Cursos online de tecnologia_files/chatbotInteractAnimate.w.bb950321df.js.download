"use strict";!function(){var t=document.getElementById("chatbot"),e=document.querySelector(".task-body")||document.querySelector(".class-page");interact(".chatbot-resizable").resizable({edges:{left:".chatbot-resizer"},listeners:{move:function(t){if(!(window.innerWidth<768)){var a=t.target.dataset,s=a.x,n=a.y;s=(parseFloat(s)||0)+t.deltaRect.left,n=(parseFloat(n)||0)+t.deltaRect.top;var c=t.rect.width;c<400||c>1e3||(Object.assign(t.target.style,{width:"".concat(c,"px")}),e&&(e.style.marginRight="".concat(c,"px")),Object.assign(t.target.dataset,{x:s,y:n}))}}}}).on("resizestart",function(){t.classList.remove("animate")}).on("resizeend",function(){t.classList.add("animate")})}();