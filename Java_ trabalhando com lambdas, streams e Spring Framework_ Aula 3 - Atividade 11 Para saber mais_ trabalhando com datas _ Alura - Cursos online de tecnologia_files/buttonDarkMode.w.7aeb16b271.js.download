"use strict";!function(){var t=document.querySelectorAll(".darkModeButton");t.forEach(function(o){o.addEventListener("click",function(){t.forEach(function(t){!function(t){var o=t.getAttribute("data-dark-mode"),a=t.getAttribute("data-light-mode");t.classList.toggle("dark-mode-action"),t.classList.toggle("light-mode-action");var e=t.classList.contains("dark-mode-action");t.innerHTML=e?o:a}(t)})})})}();